{
  "name": "Workflow 3 LLM Citation Monitor",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{"hours": 24}]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [100, 300],
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "url": "https://cbamvalid.com/sitemap.xml",
        "method": "GET",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [300, 300],
      "name": "Fetch Sitemap"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false
          }
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [500, 300],
      "name": "Contains Methodology Pages"
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [[{"node": "Fetch Sitemap", "type": "main", "index": 0}]]
    },
    "Fetch Sitemap": {
      "main": [[{"node": "Contains Methodology Pages", "type": "main", "index": 0}]]
    },
    "Contains Methodology Pages": {
      "main": [null, null]
    }
  }
}
