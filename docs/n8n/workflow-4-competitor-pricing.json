{
  "name": "Workflow 4 Competitor Pricing Monitor",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{"hours": 24}]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [100, 300],
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "url": "https://cbamvalid.com/pricing",
        "method": "GET",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [300, 300],
      "name": "Check Own Pricing Page"
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [[{"node": "Check Own Pricing Page", "type": "main", "index": 0}]]
    }
  }
}
