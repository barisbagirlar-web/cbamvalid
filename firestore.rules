rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isOwnerAdmin() {
      return signedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.admin == true
        && request.auth.token.ownerAdmin == true;
    }

    match /users/{userId} {
      allow get: if owns(userId) || isOwnerAdmin();
      allow list: if isOwnerAdmin();
      allow create, update, delete: if false;

      match /creditSummary/{documentId} {
        allow get: if owns(userId) || isOwnerAdmin();
        allow list: if isOwnerAdmin();
        allow create, update, delete: if false;
      }

      match /creditLedger/{documentId} {
        allow get, list: if owns(userId) || isOwnerAdmin();
        allow create, update, delete: if false;
      }

      match /commerceHold/{documentId} {
        allow get: if owns(userId) || isOwnerAdmin();
        allow list: if isOwnerAdmin();
        allow create, update, delete: if false;
      }
    }

    match /cbam_cases/{caseId} {
      allow get, list: if (signedIn() && resource.data.uid == request.auth.uid) || isOwnerAdmin();
      allow create, update, delete: if false;
    }

    match /cbam_reports/{reportId} {
      allow get, list: if (signedIn() && resource.data.uid == request.auth.uid) || isOwnerAdmin();
      allow create, update, delete: if false;
    }

    match /commerce_orders/{orderId} {
      allow get, list: if (signedIn() && resource.data.uid == request.auth.uid) || isOwnerAdmin();
      allow create, update, delete: if false;
    }

    match /entitlements/{entitlementId} {
      allow get, list: if (signedIn() && resource.data.uid == request.auth.uid) || isOwnerAdmin();
      allow create, update, delete: if false;
    }

    match /document_seals/{documentHash} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /case_creation_requests/{requestDigest} {
      allow read, write: if false;
    }

    match /report_requests/{requestDigest} {
      allow read, write: if false;
    }

    match /checkout_requests/{requestDigest} {
      allow read, write: if false;
    }

    match /idempotency/{requestDigest} {
      allow read, write: if false;
    }

    match /admin_idempotency/{requestDigest} {
      allow read, write: if false;
    }

    match /commerce_ledger/{entryId} {
      allow read, write: if false;
    }

    match /commerce_ledger_state/{documentId} {
      allow read, write: if false;
    }

    match /account_closures/{closureId} {
      allow read, write: if false;
    }

    match /paddle_events/{eventId} {
      allow read, write: if false;
    }

    match /seal_outbox/{reportId} {
      allow read, write: if false;
    }

    match /seal_log/{reportId} {
      allow read, write: if false;
    }

    match /source_registry_snapshots/{documentId} {
      allow read, write: if false;
    }

    match /audit_events/{documentId} {
      allow read, write: if false;
    }

    match /admin_audit/{documentId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
