rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.role == 'super_admin'
        && request.auth.token.owner == true;
    }

    function isOwnDocument(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwnDocument(userId) || isOwnerSuperAdmin();
      allow create: if isOwnDocument(userId)
        && request.resource.data.role == 'user'
        && !request.resource.data.keys().hasAny([
          'tokens',
          'credits',
          'availableCredits',
          'creditSummary',
          'customClaims',
          'owner',
          'admin',
          'ownerAdmin'
        ]);
      allow update: if isOwnDocument(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role',
          'tokens',
          'credits',
          'availableCredits',
          'creditSummary',
          'customClaims',
          'owner',
          'admin',
          'ownerAdmin'
        ]);
      allow delete: if isOwnerSuperAdmin();

      match /creditSummary/{docId} {
        allow read: if isOwnDocument(userId) || isOwnerSuperAdmin();
        allow write: if false;
      }

      match /creditLedger/{docId} {
        allow read: if isOwnDocument(userId) || isOwnerSuperAdmin();
        allow write: if false;
      }
    }

    match /cbam_reports/{reportId} {
      allow read: if (isSignedIn() && resource.data.uid == request.auth.uid) || isOwnerSuperAdmin();
      allow create: if false;
      allow update, delete: if isOwnerSuperAdmin();
    }

    match /cbam_cases/{caseId} {
      allow read: if (isSignedIn() && resource.data.uid == request.auth.uid) || isOwnerSuperAdmin();
      allow create: if false;
      allow update, delete: if isOwnerSuperAdmin();
    }

    match /case_creation_requests/{requestDigest} {
      allow read, write: if false;
    }

    match /report_requests/{requestDigest} {
      allow read, write: if false;
    }

    match /commerce_orders/{orderId} {
      allow read: if (isSignedIn() && resource.data.uid == request.auth.uid) || isOwnerSuperAdmin();
      allow create, update, delete: if false;
    }

    match /entitlements/{entitlementId} {
      allow read: if (isSignedIn() && resource.data.uid == request.auth.uid) || isOwnerSuperAdmin();
      allow create, update, delete: if false;
    }

    match /account_closure_requests/{closureId} {
      allow read, write: if false;
    }

    match /paddle_events/{eventId} {
      allow read, write: if false;
    }

    match /credit_events/{eventId} {
      allow read, write: if false;
    }

    match /commerce_ledger/{entryId} {
      allow read, write: if false;
    }

    match /commerce_manual_reviews/{reviewId} {
      allow read, write: if false;
    }

    match /admin_credit_reversals/{reversalId} {
      allow read, write: if false;
    }

    match /document_seals/{documentHash} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /seal_outbox/{reportId} {
      allow read, write: if false;
    }

    match /seal_log/{reportId} {
      allow read, write: if false;
    }

    match /source_registry_snapshots/{docId} {
      allow read, write: if false;
    }

    match /audit_events/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
