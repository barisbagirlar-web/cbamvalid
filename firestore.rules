rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSuperAdmin() {
      return request.auth != null && (request.auth.token.admin == true || request.auth.token.ownerAdmin == true);
    }

    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.tokens == 0
                    && request.resource.data.role == 'user';
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
                    && (
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['tokens'])
                      || (request.resource.data.tokens == resource.data.tokens - 1)
                    );
      allow delete: if isSuperAdmin();

      match /creditSummary/{docId} {
        allow read: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
        allow write: if false;
      }

      match /creditLedger/{docId} {
        allow read: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
        allow write: if false;
      }
    }

    match /cbam_reports/{reportId} {
      allow read: if (request.auth != null && resource.data.uid == request.auth.uid) || isSuperAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /cbam_cases/{caseId} {
      allow read: if (request.auth != null && resource.data.uid == request.auth.uid) || isSuperAdmin();
      allow create: if false;
      allow update, delete: if isSuperAdmin();
    }

    match /case_creation_requests/{requestDigest} {
      allow read, write: if false;
    }

    // Seal request documents contain deterministic request identifiers,
    // in-progress leases and retry state. They are backend-only controls.
    match /report_requests/{requestDigest} {
      allow read, write: if false;
    }

    match /commerce_orders/{orderId} {
      allow read: if (request.auth != null && resource.data.uid == request.auth.uid) || isSuperAdmin();
      allow create, update, delete: if false;
    }

    match /entitlements/{entitlementId} {
      allow read: if (request.auth != null && resource.data.uid == request.auth.uid) || isSuperAdmin();
      allow create, update, delete: if false;
    }

    match /account_closures/{closureId} {
      allow read, write: if false;
    }

    match /paddle_events/{eventId} {
      allow read, write: if false;
    }

    match /document_seals/{documentHash} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /seal_outbox/{reportId} {
      allow read, write: if false;
    }

    match /seal_log/{reportId} {
      allow read, write: if false;
    }

    match /source_registry_snapshots/{docId} {
      allow read, write: if false;
    }
    match /audit_events/{docId} {
      allow read, write: if false;
    }

    match /commerce_ledger/{docId} {
      allow read, write: if false;
    }

    match /idempotency/{docId} {
      allow read, write: if false;
    }
  }
}
